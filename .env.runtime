APP_CPU_LIMIT=2
APP_MEMORY_LIMIT=2G

CPU_CORES=10
TOTAL_MEM_MB=16384
MACHINE_PROFILE=high
CORE_API_KEY=dev-local-key
ALLOWED_ORIGINS=http://localhost:3000
# For local macOS development, point the API to a host-based core (if running core-api locally)
# or set to http://core-api:8001 when the private openwatch-core stack is running on the
# shared Docker network.
CORE_SERVICE_URL=http://host.docker.internal:8001
