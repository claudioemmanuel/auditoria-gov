{
  "name": "openwatch",
  "private": true,
  "scripts": {
    "env:detect": "node scripts/detect-resources.js",
    "docker:up": "docker compose --env-file .env.runtime up -d",
    "docker:down": "docker compose down",
    "start": "npm run env:detect && npm run docker:up",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=apps/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:js": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
