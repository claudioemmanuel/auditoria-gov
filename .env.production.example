# Production Environment — AuditorIA Gov
# ALL values marked REQUIRED must be set before `APP_ENV=production` startup.
# Generate secrets with: openssl rand -hex 32

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── Database (REQUIRED — do NOT use default credentials) ─────────────────────
POSTGRES_USER=auditoria
POSTGRES_PASSWORD=REQUIRED_change_me   # openssl rand -hex 32
POSTGRES_DB=auditoria
DATABASE_URL=postgresql+asyncpg://auditoria:REQUIRED_change_me@postgres:5432/auditoria
DATABASE_URL_SYNC=postgresql+psycopg://auditoria:REQUIRED_change_me@postgres:5432/auditoria

# ── Redis (REQUIRED — must match REDIS_PASSWORD) ──────────────────────────────
REDIS_PASSWORD=REQUIRED_change_me      # openssl rand -hex 32
REDIS_URL=redis://:REQUIRED_change_me@redis:6379/0
CELERY_BROKER_URL=redis://:REQUIRED_change_me@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REQUIRED_change_me@redis:6379/2

# ── LGPD (REQUIRED — never change once set in production) ────────────────────
CPF_HASH_SALT=REQUIRED_change_me       # openssl rand -hex 32
# WARNING: Changing this salt in production invalidates ALL CPF hashes and
#          breaks entity resolution matches. Set once and never change.

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
INTERNAL_API_KEY=REQUIRED_change_me    # openssl rand -hex 32
# Used in X-Internal-Api-Key header to authenticate /internal/* endpoints.

# Caddy reverse proxy domain (REQUIRED — must be a real DNS-resolvable domain)
API_DOMAIN=api.yourdomain.com

# CORS — comma-separated list of your Vercel domain(s)
ALLOWED_ORIGINS=https://your-project.vercel.app,https://your-custom-domain.com

# Flower basic auth — format: username:password
FLOWER_BASIC_AUTH=admin:REQUIRED_change_me

# ── Portal Transparência (REQUIRED for data ingestion) ───────────────────────
PORTAL_TRANSPARENCIA_TOKEN=your_token_from_portaldatransparencia_gov_br

# ── LLM (optional — set LLM_PROVIDER to enable AI explanations) ──────────────
LLM_PROVIDER=none   # Options: none | openai | anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# ── Rate Limits (outgoing — tune per API tier) ────────────────────────────────
RATE_LIMIT_PORTAL_TRANSPARENCIA_RPS=5
RATE_LIMIT_COMPRAS_GOV_RPS=10
RATE_LIMIT_PNCP_RPS=10
RATE_LIMIT_DEFAULT_RPS=5

# ── Rate Limits (incoming public API) ────────────────────────────────────────
PUBLIC_RATE_LIMIT_RPS=10
PUBLIC_RATE_LIMIT_BURST=30

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Data directories (bulk connectors — ensure volumes are mounted) ───────────
TSE_DATA_DIR=/data/tse
RECEITA_CNPJ_DATA_DIR=/data/receita_cnpj
