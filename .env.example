# Database
DATABASE_URL=postgresql+asyncpg://auditoria:auditoria@postgres:5432/auditoria
DATABASE_URL_SYNC=postgresql+psycopg://auditoria:auditoria@postgres:5432/auditoria
POSTGRES_USER=auditoria
POSTGRES_PASSWORD=auditoria
POSTGRES_DB=auditoria

# Redis
REDIS_URL=redis://redis:6379/0
# Set a strong random password in production; leave empty for local dev
REDIS_PASSWORD=

# Portal Transparência
PORTAL_TRANSPARENCIA_TOKEN=

# LLM
# LLM_PROVIDER options: none (default), openai, anthropic
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set LLM_PROVIDER=anthropic and ANTHROPIC_API_KEY to use Claude as LLM backend.
# Embeddings still use OpenAI (Anthropic has no embeddings API) — OPENAI_API_KEY required.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# Rate Limits (outgoing to gov APIs)
RATE_LIMIT_PORTAL_TRANSPARENCIA_RPS=5
RATE_LIMIT_COMPRAS_GOV_RPS=10
RATE_LIMIT_PNCP_RPS=10
RATE_LIMIT_DEFAULT_RPS=5

# Rate Limits (incoming public portal)
PUBLIC_RATE_LIMIT_RPS=10
PUBLIC_RATE_LIMIT_BURST=30

# Cache
CACHE_TTL_SECONDS=300

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# LGPD — REQUIRED: generate a strong random value before production deployment (LGPD compliance)
CPF_HASH_SALT=change-me-in-production

# App
APP_ENV=development
LOG_LEVEL=INFO

# Security — REQUIRED in production
# Comma-separated list of allowed CORS origins (e.g. https://your-app.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000
# API key for internal endpoints — generate with: openssl rand -hex 32
INTERNAL_API_KEY=dev-internal-key-change-in-production
# Flower basic auth — format: username:password
FLOWER_BASIC_AUTH=CHANGE_ME_username:change-me-strong-password
# NEXT_PUBLIC_API_URL must be an HTTPS URL when deploying to Vercel
# NEXT_PUBLIC_API_URL=https://your-api.example.com
