# OpenWatch public gateway — Caddy reverse proxy.
# Handles TLS termination for the public API.
# Replace the domain below with your actual domain before deploying.

{$API_DOMAIN:api.example.com} {
    reverse_proxy localhost:8000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    log {
        output file /var/log/caddy/api.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}
